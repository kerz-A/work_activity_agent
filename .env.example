# =============================================================================
# Work Activity Agent — пример .env
# Скопируйте в .env и отредактируйте под свой профиль (local или cloud).
# =============================================================================

# --------------------------- ПРОФИЛЬ LLM -------------------------------------
# local — локальная Ollama (бесплатно, оффлайн, требуется ollama serve)
# cloud — Anthropic / OpenAI / OpenRouter / Groq (требуется API ключ)
LLM_PROFILE=local

# --------------------------- LOCAL: Ollama -----------------------------------
# Адрес запущенного Ollama. Зависит от профиля Docker compose:
#   - host-llm  (РЕКОМЕНДУЕТСЯ для GPU 6GB и Windows): http://host.docker.internal:11434
#                Ollama запускается нативно на хосте (`ollama serve`).
#                Обходит WSL2 GPU passthrough overhead.
#   - local-llm (Ollama в sidecar контейнере):         http://ollama:11434
#                Производительность хуже из-за WSL2 GPU passthrough.
#   - native (без Docker, прямой запуск):              http://localhost:11434
LLM_OLLAMA_BASE_URL=http://host.docker.internal:11434

# --------------------------- CLOUD: API ключи --------------------------------
# Достаточно одного ключа (соответствующего configs/models.cloud.yaml).
# По умолчанию models.cloud.yaml использует Anthropic — выставьте ANTHROPIC.
LLM_ANTHROPIC_API_KEY=sk-ant-...
# LLM_OPENAI_API_KEY=sk-...
# LLM_OPENROUTER_API_KEY=sk-or-v1-...
# LLM_GROQ_API_KEY=gsk_...
# LLM_HUGGINGFACE_API_KEY=hf_...

# --------------------------- ЛИМИТЫ И БЕЗОПАСНОСТЬ ---------------------------
LLM_MAX_CONCURRENT_VISION=2
LLM_REQUEST_TIMEOUT_S=180

# Stop при превышении бюджета (только для cloud — у Ollama cost=0).
# Установите 0 чтобы отключить проверку.
LLM_SOFT_BUDGET_USD=5.0

# Privacy strict mode: при ошибке image redaction скрин НЕ попадает в Vision.
# В Docker Tesseract всегда есть, поэтому true безопасно.
# На голой машине без Tesseract выставьте false (с риском утечки PII).
LLM_PRIVACY_STRICT=true

# --------------------------- ПЕРЕОПРЕДЕЛЕНИЕ MODELS.YAML ---------------------
# По умолчанию: configs/models.{LLM_PROFILE}.yaml.
# Раскомментируйте для использования своего файла:
# LLM_MODELS_CONFIG_PATH=configs/models.custom.yaml

# --------------------------- ПУТИ --------------------------------------------
INPUT_DIR=./data/screenshots
OUTPUT_DIR=./data/reports
CHECKPOINT_DIR=./.checkpoints

# Куда складывать редактированные копии скрин-шотов. По умолчанию подкаталог
# checkpoint_dir/redacted (writable). Меняйте только если нужно вынести
# их в отдельный том (например, NFS), не рядом с checkpoint'ами.
# REDACTED_DIR=./.checkpoints/redacted

# Сколько минут "стоит" один скриншот для подсчёта breakdown в отчётах
# (используется когда в manifest не указан tracked_minutes). Бизнес-параметр.
# MINUTES_PER_SCREENSHOT=5

# --------------------------- ЛОГИРОВАНИЕ -------------------------------------
OBSERVABILITY_LOG_LEVEL=INFO
OBSERVABILITY_JSON_LOGS=true
OBSERVABILITY_ENABLE_TRACING=false

# LangSmith (опционально) — трассировка графа
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=ls_...
LANGSMITH_PROJECT=work-activity-agent
LANGSMITH_HIDE_INPUTS=true
