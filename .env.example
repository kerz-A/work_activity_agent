# LLM API ключи (хотя бы один требуется для live прогонов).
# Дефолтно используем OpenRouter (бесплатные open-source модели): https://openrouter.ai/keys
LLM_OPENROUTER_API_KEY=sk-or-v1-...

# Опционально: HuggingFace для embeddings (бесплатно): https://huggingface.co/settings/tokens
LLM_HUGGINGFACE_API_KEY=hf_...

# Опционально: при желании сменить провайдера через configs/models.yaml
LLM_GROQ_API_KEY=gsk_...
LLM_ANTHROPIC_API_KEY=sk-ant-...
LLM_OPENAI_API_KEY=sk-...

# Лимиты LLM
LLM_MAX_CONCURRENT_VISION=4
LLM_REQUEST_TIMEOUT_S=60
LLM_SOFT_BUDGET_USD=5.0

# Observability
OBSERVABILITY_LOG_LEVEL=INFO
OBSERVABILITY_JSON_LOGS=true
OBSERVABILITY_ENABLE_TRACING=false

# LangSmith (опц.) — для трассировки графа
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=ls_...
LANGSMITH_PROJECT=work-activity-agent
LANGSMITH_HIDE_INPUTS=true

# Пути
INPUT_DIR=./data/screenshots
OUTPUT_DIR=./data/reports
CHECKPOINT_DIR=./.checkpoints
